---
import Icon from "../components/Icon.astro";
import PublicationCard from "../components/PublicationCard.astro";
import RichText from "../components/RichText.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { profile } from "../data/site";
import { getPublicationMap, getSelectedPublications, serializePublication } from "../lib/publications";

const selectedPublications = (await getSelectedPublications(4)).map(serializePublication);
const publicationMap = await getPublicationMap();
---

<BaseLayout title={profile.name} description={profile.summary} currentPath="/" bodyClass="home-page">
  <section class="hero">
    <div class="page-shell hero__grid">
      <div class="hero__copy" data-reveal>
        <p class="eyebrow">{profile.hero.eyebrow}</p>
        <h1 class="hero__headline">{profile.hero.title}</h1>
        <p class="hero__lede">{profile.hero.intro}</p>

        <div class="hero__actions">
          <a class="button" href={profile.hero.primaryCta.href}>{profile.hero.primaryCta.label}</a>
          <a class="button button--ghost" href={profile.hero.secondaryCta.href}>{profile.hero.secondaryCta.label}</a>
        </div>

        <div class="quick-links" aria-label="Profile links">
          {
            profile.quickLinks.map((link) => (
              <a
                class="link-pill"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                <Icon name={link.icon} class="icon" />
                <span>{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <aside class="hero__aside" data-reveal>
        <div class="hero-portrait">
          <img src="/images/zcaiam.jpg" alt={`Portrait of ${profile.name}`} />
        </div>

        <div class="hero__details">
          <p class="snapshot-card__label">Current position</p>
          <h2>{profile.role}</h2>
          <p class="muted">
            <a class="text-link" href={profile.institutionHref} target="_blank" rel="noreferrer">
              {profile.institution}
            </a>
          </p>
        </div>

        <dl class="hero-facts">
          <div>
            <dt>Location</dt>
            <dd>{profile.location}</dd>
          </div>
          <div>
            <dt>Support</dt>
            <dd>Hong Kong PhD Fellowship Scheme (HKPFS)</dd>
          </div>
          <div>
            <dt>Visiting scholar</dt>
            <dd>University of Oxford</dd>
          </div>
        </dl>

        <div class="hero-stats">
          {
            profile.hero.stats.map((stat) => (
              <div class="hero-stat">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Profile</p>
        <h2 class="section-title">Background, affiliations, and current research context.</h2>
        <p class="section-copy">
          This page provides a concise overview of my academic background, institutional context, and current lines of work.
        </p>
      </div>

      <div class="snapshot-grid">
        <article class="card" data-reveal>
          <p class="snapshot-card__label">About</p>
          {profile.bio.map((paragraph) => <RichText block={paragraph} class="text-block" />)}
        </article>

        <article class="card" data-reveal>
          <p class="snapshot-card__label">Affiliations</p>
          <div class="tag-row">
            {
              profile.affiliations.map((item) => (
                <span class="tag">{item.label}</span>
              ))
            }
          </div>
          <div class="footer-list footer-list--rich">
            {
              profile.affiliations.map((item) => (
                <div>
                  <strong>{item.label}:</strong> <RichText block={item.value} as="span" />
                </div>
              ))
            }
          </div>
        </article>

        <article class="card" data-reveal>
          <p class="snapshot-card__label">Research note</p>
          <RichText block={profile.publicationNote} class="text-block" />
        </article>

        <article class="card" data-reveal>
          <p class="snapshot-card__label">Current focus</p>
          <ul>
            {profile.researchAreas.map((area) => <li>{area.title}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Research themes</p>
        <h2 class="section-title">Current areas of work.</h2>
      </div>

      <div class="grid-two">
        {
          profile.researchAreas.map((area) => (
            <article class="research-card" data-reveal>
              <h3>{area.title}</h3>
              <p>{area.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Selected publications</p>
        <h2 class="section-title">Recent papers and ongoing directions.</h2>
        <p class="section-copy">
          A complete, filterable publication list with local PDFs where available is maintained on the publications page.
        </p>
      </div>

      <div class="publications-grid">
        {
          selectedPublications.map((publication) => (
            <PublicationCard publication={publication} featured />
          ))
        }
      </div>

      <div class="cta-actions" data-reveal>
        <a class="button button--ghost" href="/publications/">Open full publications list</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Research themes</p>
        <h2 class="section-title">Themes that connect the publication list.</h2>
        <p class="section-copy">Each group below links related papers through a shared research question.</p>
      </div>

      <div class="projects-grid">
        {
          projects.map((project) => {
            const related = project.publicationIds
              .flatMap((id) => {
                const publication = publicationMap.get(id);
                return publication ? [publication] : [];
              })
              .slice(0, 2);

            return (
              <article class="project-card" data-reveal>
                <p class="pill">{project.period}</p>
                <h3>{project.title}</h3>
                <p>{project.summary}</p>
                <ul>
                  {project.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
                {
                  related.length > 0 && (
                    <div class="tag-row">
                      {related.map((publication) => <span class="tag">{publication.data.venueShort ?? publication.data.year}</span>)}
                    </div>
                  )
                }
                <div class="publication-card__actions">
                  <a class="button button--ghost button--small" href={`/project/#${project.id}`}>
                    View theme
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>

      <div class="cta-actions" data-reveal>
        <a class="button" href="/project/">Open research overview</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Academic path</p>
        <h2 class="section-title">Training, milestones, and recent publications.</h2>
      </div>

      <div class="timeline">
        {
          profile.milestones.map((milestone) => (
            <article class="timeline-item" data-reveal>
              <div class="timeline-item__period">{milestone.period}</div>
              <div>
                {
                  milestone.href ? (
                    <h3>
                      <a class="text-link" href={milestone.href} target="_blank" rel="noreferrer">
                        {milestone.title}
                      </a>
                    </h3>
                  ) : (
                    <h3>{milestone.title}</h3>
                  )
                }
                <RichText block={milestone.detail} class="text-block" />
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="page-shell">
      <div class="grid-two">
        <article class="card" data-reveal>
          <p class="snapshot-card__label">Service</p>
          <h3>Academic service</h3>
          <ul>
            {profile.service.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="cta-panel" data-reveal>
          <p class="eyebrow">Contact</p>
          <h3>Open to research discussions and collaboration.</h3>
          <p>
            If your work overlaps with zero-knowledge proofs, distributed randomness, mechanism design, or smart contract
            analysis, feel free to get in touch.
          </p>
          <div class="cta-actions">
            <a class="button" href="/contact/">Contact details</a>
            <a class="button button--ghost" href={`mailto:${profile.email}`}>Email directly</a>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
