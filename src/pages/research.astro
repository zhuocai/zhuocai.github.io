---
import PublicationCard from "../components/PublicationCard.astro";
import ResearchDirectionCard from "../components/ResearchDirectionCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";
import { projects } from "../data/projects";
import { getPublicationMap, getAllPublications, serializePublication } from "../lib/publications";
import { getAllDirections, serializeDirection } from "../lib/directions";

const publicationMap = await getPublicationMap();
const allPublications = (await getAllPublications()).map(serializePublication);
const manuscripts = allPublications.filter((p) => p.type === "manuscript");
const directions = (await getAllDirections()).map(serializeDirection);
const hasOngoing = manuscripts.length > 0 || directions.length > 0;

const primaryProjects = projects.filter((p) => p.category === "primary");
const nonPrimaryProjects = projects.filter((p) => p.category === "prior" || p.category === "earlier");

const makeGroup = (project: (typeof projects)[number]) => ({
  ...project,
  publications: project.publicationIds
    .flatMap((id) => {
      const publication = publicationMap.get(id);
      return publication ? [serializePublication(publication)] : [];
    })
});

const primaryGroups = primaryProjects.map(makeGroup);
const nonPrimaryGroups = nonPrimaryProjects.map(makeGroup);
---

<BaseLayout
  title="Research"
  description="Research thrusts and paper-level explanations across proof systems, cryptographic coordination, and blockchain mechanism design."
  currentPath="/research/"
>
  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Research</p>
        <h1 class="section-title">Three research thrusts and representative papers.</h1>
        <p class="section-copy">My research spans three interconnected directions in cryptography, distributed systems, and blockchain economics. Prior and earlier work follows below.</p>
      </div>
      <p class="section-lead" data-reveal>{profile.hero.intro}</p>
    </div>
  </section>

  {hasOngoing && (
    <section class="section" id="ongoing">
      <div class="page-shell">
        <div class="section-header" data-reveal>
          <p class="eyebrow">Work in Progress</p>
          <h2 class="section-title">Ongoing directions and papers under review.</h2>
          <p class="section-copy">
            These include manuscripts currently under submission and active research directions
            without a published paper yet.
          </p>
        </div>

        {manuscripts.length > 0 && (
          <div class="publications-grid">
            {manuscripts.map((pub) => (
              <PublicationCard
                publication={pub}
                showAbstract
                anchorId={`paper-${pub.id}`}
              />
            ))}
          </div>
        )}

        {directions.length > 0 && (
          <div class="home-directions-grid" style="margin-top: 1.5rem;">
            {directions.map((direction) => (
              <ResearchDirectionCard
                direction={direction}
                relatedPublicationEntries={direction.relatedPublications
                  .map((id) => allPublications.find((p) => p.id === id))
                  .filter((p): p is NonNullable<typeof p> => p !== undefined)}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {
    primaryGroups.map((project) => (
      <section class="section" id={project.id}>
        <div class="page-shell">
          <div class="section-header" data-reveal>
            <p class="eyebrow">{project.period}</p>
            <h2 class="section-title">{project.title}</h2>
            <p class="section-copy">{project.narrative}</p>
          </div>

          <div class="grid-two project-overview">
            <article class="card" data-reveal>
              <p class="snapshot-card__label">Context</p>
              <h3>Why this direction matters</h3>
              <p>{project.significance}</p>
            </article>

            <article class="card" data-reveal>
              <p class="snapshot-card__label">Core ideas</p>
              <h3>Recurring technical ingredients</h3>
              <ul>
                {project.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </article>
          </div>

          <div class="publications-grid">
            {
              project.publications.map((publication) => (
                <PublicationCard
                  publication={publication}
                  showAbstract
                  anchorId={`paper-${publication.id}`}
                />
              ))
            }
          </div>
        </div>
      </section>
    ))
  }

  {nonPrimaryGroups.length > 0 && (
    <section class="section" id="prior-work">
      <div class="page-shell">
        <div class="section-header" data-reveal>
          <p class="eyebrow">Prior and Earlier Work</p>
          <h2 class="section-title">Work predating the current three-thrust agenda.</h2>
          <p class="section-copy">These directions contributed to my research background and inform current work, but are not active primary thrusts.</p>
        </div>

        {nonPrimaryGroups.map((project) => (
          <div class="project-prior-item" id={project.id} data-reveal>
            <div class="project-prior-item__header">
              <span class="pill">{project.period}</span>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
            </div>

            <div class="publications-grid">
              {project.publications.map((publication) => (
                <PublicationCard
                  publication={publication}
                  showAbstract
                  anchorId={`paper-${publication.id}`}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

