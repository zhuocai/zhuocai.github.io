---
import RichText from "../components/RichText.astro";
import PublicationsExplorer from "../components/react/PublicationsExplorer";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";
import { getAllPublications, serializePublication } from "../lib/publications";

const publications = (await getAllPublications()).map(serializePublication);
---

<BaseLayout
  title="Publications"
  description="A searchable list of Zhuo Cai's publications across cryptography, game theory, and blockchain systems."
  currentPath="/publications/"
>
  <section class="section">
    <div class="page-shell">
      <div class="section-header" data-reveal>
        <p class="eyebrow">Publications</p>
        <h1 class="section-title">A searchable publication list with local PDFs where possible.</h1>
        <div class="section-copy section-copy--stack">
          <RichText block={profile.publicationNote} class="text-block" />
          <p>Browse {publications.length} papers by year, venue, and tag.</p>
        </div>
      </div>

      <div data-reveal>
        <PublicationsExplorer client:load publications={publications} />
      </div>
    </div>
  </section>
</BaseLayout>
