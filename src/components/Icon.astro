---
type IconName =
  | "scholar"
  | "cv"
  | "github"
  | "linkedin"
  | "email"
  | "external"
  | "sun"
  | "moon"
  | "spark";

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className } = Astro.props;
---

{
  name === "scholar" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M12 4 3.5 8.5 12 13l8.5-4.5L12 4Z" />
      <path d="M6 10.8V15c0 1.9 2.7 3.5 6 3.5s6-1.6 6-3.5v-4.2" />
      <path d="M20.5 8.5V15.5" />
    </svg>
  )
}
{
  name === "cv" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M8 3.5h6l4 4V20.5H8a2 2 0 0 1-2-2V5.5a2 2 0 0 1 2-2Z" />
      <path d="M14 3.5v4h4" />
      <path d="M10 12h6" />
      <path d="M10 16h6" />
    </svg>
  )
}
{
  name === "github" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M12 .8a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6V21c-3.3.7-4-1.4-4-1.4-.6-1.3-1.4-1.7-1.4-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.7 2.7 1.2 3.4.9.1-.8.4-1.2.8-1.5-2.7-.3-5.6-1.4-5.6-6.2 0-1.4.5-2.6 1.2-3.5-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.6 1.2A12.4 12.4 0 0 1 12 6.9c1.1 0 2.1.1 3.1.4 2.6-1.5 3.6-1.2 3.6-1.2.6 1.6.2 2.9.1 3.2.8.9 1.2 2.1 1.2 3.5 0 4.9-2.9 5.9-5.7 6.2.5.4.9 1.2.9 2.4v3.5c0 .3.2.7.8.6A12 12 0 0 0 12 .8Z" />
    </svg>
  )
}
{
  name === "linkedin" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M5.4 8.9H1.7V22h3.7V8.9ZM3.5 7.2A2.1 2.1 0 1 0 3.5 3a2.1 2.1 0 0 0 0 4.2ZM22 22v-7.1c0-3.8-2-5.6-4.8-5.6-2.2 0-3.2 1.2-3.7 2v-1.7H9.8c.1 1.1 0 12.4 0 12.4h3.7v-6.9c0-.4 0-.7.1-1 .3-.7.9-1.5 2.1-1.5 1.5 0 2.2 1.1 2.2 2.8V22H22Z" />
    </svg>
  )
}
{
  name === "email" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m4 7 8 6 8-6" />
    </svg>
  )
}
{
  name === "external" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M14 5h5v5" />
      <path d="M10 14 19 5" />
      <path d="M19 13v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h4" />
    </svg>
  )
}
{
  name === "sun" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <circle cx="12" cy="12" r="4.5" />
      <path d="M12 2.5v2.2M12 19.3v2.2M4.7 4.7l1.6 1.6M17.7 17.7l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.7 19.3l1.6-1.6M17.7 6.3l1.6-1.6" />
    </svg>
  )
}
{
  name === "moon" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M20 14.3A7.9 7.9 0 0 1 9.7 4a8.7 8.7 0 1 0 10.3 10.3Z" />
    </svg>
  )
}
{
  name === "spark" && (
    <svg class={className} viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="m12 2 1.9 5.6L19.5 9l-5.6 1.4L12 16l-1.9-5.6L4.5 9l5.6-1.4L12 2Z" />
      <path d="m19 16 .9 2.6 2.6.9-2.6.9-.9 2.6-.9-2.6-2.6-.9 2.6-.9.9-2.6Z" />
    </svg>
  )
}
