---
import { profile } from "../data/site";
import Icon from "./Icon.astro";
---

<footer class="site-footer">
  <div class="page-shell site-footer__grid">
    <div class="site-footer__brand">
      <p class="eyebrow">Academic profile</p>
      <h2>{profile.name}</h2>
      <p>{profile.summary}</p>
      <div class="footer-links">
        <a class="footer-link" href="/publications/">Publications</a>
        <a class="footer-link" href="/research/">Research themes</a>
      </div>
    </div>

    <div>
      <p class="site-footer__heading">Links</p>
      <div class="footer-links">
        {
          profile.quickLinks.map((link) => (
            <a class="footer-link" href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
              <Icon name={link.icon} class="icon" />
              <span>{link.label}</span>
            </a>
          ))
        }
      </div>
    </div>

    <div>
      <p class="site-footer__heading">Research areas</p>
      <ul class="footer-list">
        {
          profile.researchAreas.slice(0, 3).map((area) => (
            <li>{area.title}</li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
